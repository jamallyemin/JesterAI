{
    "manifest_version": 3,
    "name": "Jester AI",
    "version": "1.1",
    "description": "AI-powered Phishing Detection",
    "icons": {
        "128": "icon128.png"
    },
    "permissions": [
        "notifications",
        "activeTab", 
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}